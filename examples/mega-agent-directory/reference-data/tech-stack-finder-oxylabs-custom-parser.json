    {
      "parameters": {
        "text": "=You are intelligent information extractor. Your goal is to extract realestate software tool names from unstructured text into a JSON format.You will be getting input containing 3 headings. \"Analytics and Tracking\", \"Content Management System\" and \"Agency\". You might not receive all the inputs all the time. \n\nYou need to identify and extract all the tool names mentioned under \"Content Management System\" and \"Agency\" accurately without missing any tool name.\n\nIdentify the tool names which are related to CRM or Realestate in \"Analytics and Tracking\". \nNever add any tools on your own. Just extract from the input. Don't miss any relevant tools.\n\nPlease output only valid JSON, without any markdown, code block, or extra text. \n\nInput: {{ $json['Analytics and Tracking'] }} \n\n{{ $json['Content Management System'] }}\n\n{{ $json.Agency }}\n\n",
        "schemaType": "manual",
        "inputSchema": "{\n  \"oneOf\": [\n    {\n      \"type\": \"object\",\n      \"properties\": {\n        \"marketing_tools\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\"\n          }\n        }\n      },\n      \"required\": [\"marketing_tools\"]\n    }  \n  ]\n}\n",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.informationExtractor",
      "typeVersion": 1.2,
      "position": [
        -3216,
        272
      ],
      "id": "839b5018-f63a-44a0-865c-8457b1d120fe",
      "name": "Information Extractor",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// -------------------------------------------\n// UPDATED ALLOWED CRM LIST\n// -------------------------------------------\nconst crmList = [\n  \"Follow Up Boss\",\n  \"Sierra Interactive\",\n  \"KW Command\",\n  \"BoldTrail\",\n  \"KVCore\",\n  \"Lofty (Chime)\",\n  \"Chime\",\n  \"CINC\",\n  \"Real Geeks\",\n  \"iHouseWeb\",\n  \"Agent Image\",\n  \"Boomtown ROI\",\n  \"Boomtown\",\n  \"Brivity\",\n  \"Commissions Inc\",\n  \"Curaytor\",\n  \"Hire Aiva\",\n  \"IDXBroker\",\n  \"Inside Real Estate\",\n  \"MoxiWorks\",\n  \"RealScout\",\n  \"Sisu\",\n  \"Spark Platform\",\n  \"Terabitz\",\n  \"Wolfnet\",\n  \"iHomefinder\",\n  \"Homebot\",\n  \"Realvolution\"\n];\n\n// -------------------------------------------\n// FUZZY CRM CHECK\n// -------------------------------------------\nfunction isCRM(tool) {\n  if (!tool) return false;\n  const name = String(tool).toLowerCase();\n  return crmList.some(crm => name.includes(crm.toLowerCase()));\n}\n\n// -------------------------------------------\n// MAIN EXTRACTION LOGIC\n// -------------------------------------------\nconst item = $input.first().json.data[0];\nlet collected = [];\n\n// --------------------------------------------------\n// 1) Collect from output.marketing_tools\n// --------------------------------------------------\nif (Array.isArray(item.output?.marketing_tools)) {\n  collected.push(...item.output.marketing_tools);\n}\n\n// --------------------------------------------------\n// 2) Collect from marketing_tools1, marketing_tools2, etc.\n//    (Can be array or stringified JSON)\n// --------------------------------------------------\nfor (const key of Object.keys(item)) {\n  if (key.startsWith(\"marketing_tools\") && key !== \"output\") {\n    const raw = item[key];\n\n    if (Array.isArray(raw)) {\n      collected.push(...raw);\n      continue;\n    }\n\n    if (typeof raw === \"string\") {\n      try {\n        const parsed = JSON.parse(raw);\n        if (Array.isArray(parsed)) collected.push(...parsed);\n      } catch {\n        // ignore\n      }\n    }\n  }\n}\n\n// -------------------------------------------\n// CLEANING\n// -------------------------------------------\ncollected = collected\n  .filter(t => t && t.trim() !== \"\")\n  .map(t => t.trim());\n\n// remove duplicates\ncollected = [...new Set(collected)];\n\n// Backup copy BEFORE removing \"Not Found\"\nconst originalCollected = [...collected];\n\n// Remove \"Not Found\" for normal logic\ncollected = collected.filter(t => t !== \"Not Found\");\n\n// -------------------------------------------\n// SPECIAL CASE CHECK\n// -------------------------------------------\nconst allNotFound =\n  originalCollected.length === 0 ||\n  originalCollected.every(t => t === \"Not Found\");\n\nif (item.source === \"error\" && allNotFound) {\n  return [\n    {\n      output: {\n        crm: [],\n        marketing_tools: [\"Not found on Buildwith\"]\n      }\n    }\n  ];\n}\n\n// -------------------------------------------\n// NORMAL CLASSIFICATION\n// -------------------------------------------\nconst crm = [];\nconst marketing = [];\n\nfor (const tool of collected) {\n  if (isCRM(tool)) crm.push(tool);\n  else marketing.push(tool);\n}\n\n// -------------------------------------------\n// FINAL OUTPUT FORMAT\n// -------------------------------------------\nreturn [\n  {\n    output: {\n      crm,\n      marketing_tools: marketing\n    }\n  }\n];\n"
      },
