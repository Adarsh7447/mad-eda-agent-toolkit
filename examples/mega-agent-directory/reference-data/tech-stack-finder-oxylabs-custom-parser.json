    {
      "parameters": {
        "jsCode": "let result = {};\nlet sourceError = false;\n\nfor (const item of items) {\n  // Detect explicit error input\n  if (item.json?.source === \"error\") {\n    sourceError = true;\n  }\n\n  const heading = item.json?.heading;\n  let text = item.json?.text || \"\";\n\n  if (typeof heading !== \"string\" || !text) continue;\n\n  // Remove duplicate consecutive words before \"Usage Statistics\"\n  text = text.replace(/\\b(\\w+)\\s+\\1(?=\\s+Usage Statistics)/gi, '$1');\n\n  // Prepend heading to text\n  let finalText = `${heading}: ${text}`;\n\n  if (heading === \"Analytics and Tracking\") {\n    result[\"Analytics and Tracking\"] = finalText;\n  } else if (heading === \"Content Management System\") {\n    result[\"Content Management System\"] = finalText;\n  } else if (heading === \"Agency\") {\n    result[\"Agency\"] = finalText;\n  }\n}\n\n// If any error exists → return ONLY { source: \"error\" }\nif (sourceError) {\n  return [\n    {\n      json: {\n        source: \"error found\"\n      }\n    }\n  ];\n}\n\n// Normal return\nreturn [\n  { json: result }\n];\n"
      },
